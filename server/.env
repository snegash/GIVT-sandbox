# Copy to server/.env and fill in. Never commit the real file.

PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Local PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:123@localhost:5432/givt
# Local Postgres usually needs no SSL. Set to "true" when you point this at Supabase.
DATABASE_SSL=false

# Long random string used to sign login tokens.
JWT_SECRET=givt_9f3kd82ncoeu57zqmxp10walq

# Server-side Anthropic key (the browser never sees it).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
